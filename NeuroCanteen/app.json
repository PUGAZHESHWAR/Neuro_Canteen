{
  "expo": {
    "name": "NeuroCanteen",
    "slug": "neurocanteen",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.neurocanteen.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.neurocanteen.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "scheme": "neurocanteen",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "91a9fc2b-c27b-4a47-9f46-5dfb8ed31a4e"
      }
    },
    "owner": "pugazh-expo"
  }
}
